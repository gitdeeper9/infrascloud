# INFRAS-CLOUD Development Dockerfile
# Atmospheric Infrasound & Severe Weather Acoustic Signatures
# Version: 1.0.0 | DOI: 10.5281/zenodo.18952438

FROM python:3.10-slim

LABEL maintainer="Samir Baladi <gitdeeper@gmail.com>"
LABEL description="INFRAS-CLOUD Development Environment"
LABEL version="1.0.0"

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    DEBIAN_FRONTEND=noninteractive \
    INFRA_ENV=development

# Install system dependencies including development tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    g++ \
    gfortran \
    cmake \
    make \
    pkg-config \
    libhdf5-dev \
    libnetcdf-dev \
    libfftw3-dev \
    libusb-1.0-0-dev \
    libatlas-base-dev \
    libopenblas-dev \
    liblapack-dev \
    libsuitesparse-dev \
    git \
    curl \
    wget \
    vim \
    nano \
    htop \
    tmux \
    screen \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create working directory
WORKDIR /app

# Copy requirements first for better caching
COPY requirements.txt requirements-dev.txt ./

# Install Python dependencies
RUN pip install --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -r requirements-dev.txt && \
    pip install --no-cache-dir jupyter jupyterlab ipykernel ipywidgets

# Copy application code
COPY . .

# Install in development mode
RUN pip install -e .[dev,ml,gpu,docs,test,sensors,web,all]

# Create necessary directories
RUN mkdir -p /data/raw /data/processed /data/aisi /data/events /logs /config /notebooks

# Copy sample notebooks
COPY notebooks/ /notebooks/

# Set environment variables
ENV PYTHONPATH=/app:$PYTHONPATH \
    INFRA_HOME=/app \
    INFRA_DATA=/data \
    INFRA_CONFIG=/config \
    INFRA_LOGS=/logs

# Expose ports
EXPOSE 5000 8000 8888 9090

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import requests; requests.get('http://localhost:5000/health')" || exit 1

# Default command for development
CMD ["/bin/bash"]
