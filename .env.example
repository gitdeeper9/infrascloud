# ⚡ INFRAS-CLOUD Environment Configuration
# Atmospheric Infrasound & Severe Weather Acoustic Signatures
# Version: 1.0.0 | DOI: 10.5281/zenodo.18952438

# ============================================
# STATION CONFIGURATION
# ============================================
STATION_ID="IS42_AZORES"
STATION_NAME="Azores Infrasound Array"
STATION_LAT=38.5
STATION_LON=-28.5
STATION_ELEV=100
NETWORK="IMS"
DEPLOYMENT_DATE="2026-03-11"
TIMEZONE="UTC-1"

# ============================================
# MICROBAROMETER ARRAY CONFIGURATION
# ============================================
# MB2005 Microbarometer Array (4-8 elements)
MB2005_ENABLED=true
MB2005_ELEMENTS=8
MB2005_BASE_PORT="/dev/ttyUSB"
MB2005_BAUDRATE=115200
MB2005_SAMPLE_RATE=20
MB2005_SPACING=2000  # meters (2 km)
MB2005_GEOMETRY="octagonal"
MB2005_DYNAMIC_RANGE=120
MB2005_CALIBRATION_FILE="config/calibration/mb2005_2026.json"

# ============================================
# DIGITIZER CONFIGURATION
# ============================================
DIGITIZER_ENABLED=true
DIGITIZER_TYPE="centaur"
DIGITIZER_IP="192.168.1.100"
DIGITIZER_PORT=5000
DIGITIZER_SAMPLE_RATE=20
DIGITIZER_CHANNELS=8
DIGITIZER_TIMING="gps"

# ============================================
# WEATHER STATION (for α_air correction)
# ============================================
WEATHER_ENABLED=true
WEATHER_TYPE="vaisala_wxt536"
WEATHER_PORT="/dev/ttyUSB8"
WEATHER_BAUDRATE=19200
WEATHER_INTERVAL=60

# ============================================
# WAVE PARAMETERS
# ============================================
WAVELET_FMIN=0.001
WAVELET_FMAX=20
WAVELET_OMEGA0=6
WAVELET_WINDOW=60

BEAMFORMING_WINDOW=256
BEAMFORMING_OVERLAP=0.75
BEAMFORMING_WEIGHTING="dolph-chebyshev"

COHERENCE_THRESHOLD=0.60
DETECTION_MIN_BINS=3

# ============================================
# AISI THRESHOLDS
# ============================================
AISI_CRITICAL=0.80
AISI_ELEVATED=0.55
AISI_BACKGROUND=0.00
AISI_UPDATE_INTERVAL=60

# ============================================
# DATA STORAGE
# ============================================
DATA_DIR="/data/infrascloud"
RAW_DATA_DIR="${DATA_DIR}/raw"
PROCESSED_DATA_DIR="${DATA_DIR}/processed"
AISI_DATA_DIR="${DATA_DIR}/aisi"
EVENTS_DATA_DIR="${DATA_DIR}/events"
BACKUP_DIR="${DATA_DIR}/backup"

RETENTION_DAYS=365
DATA_FORMAT="miniseed"
COMPRESSION="gzip"

# ============================================
# DATABASE (Optional - for multi-station)
# ============================================
DB_TYPE="timescaledb"  # or "sqlite"
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="infrascloud"
DB_USER="infrauser"
DB_PASSWORD="changeme"
DB_POOL_SIZE=20

TIMESCALE_CHUNK_INTERVAL="7 days"
TIMESCALE_RETENTION_PERIOD="10 years"
TIMESCALE_COMPRESSION=true

# ============================================
# REDIS (Cache & Message Queue)
# ============================================
REDIS_ENABLED=false
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# ============================================
# PROCESSING
# ============================================
PROCESSING_INTERVAL=3600
PROCESSING_BATCH_SIZE=1000
PROCESSING_WORKERS=4
PROCESSING_USE_GPU=false

# ============================================
# NETWORK & SYNC
# ============================================
SYNC_INTERVAL=3600
CLOUD_ENDPOINT="https://api.infrascloud.netlify.app"
USE_4G=true
COMPRESS_DATA=true

# ============================================
# ALERTING
# ============================================
ALERTS_ENABLED=true
ALERT_CHECK_INTERVAL=300
ALERT_EMAIL="operator@infrascloud.org"
ALERT_SLACK_WEBHOOK=""
ALERT_SMS_ENABLED=false
ALERT_SMS_NUMBER=""

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="INFO"
LOG_FILE="logs/infrascloud.log"
LOG_MAX_SIZE="100MB"
LOG_BACKUP_COUNT=10
